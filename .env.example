# Copy to .env and fill in values.
# All variables here are read by docker-compose and by the backend (pydantic-settings).

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Postgres password — used by both the postgres service and the backend DATABASE_URL.
# Change this for any environment beyond your local machine.
POSTGRES_PASSWORD=change_me_in_production

# Override the default DATABASE_URL if you're not using docker-compose
# (e.g. pointing at an external Postgres instance).
# The docker-compose.yml constructs this automatically from POSTGRES_PASSWORD;
# only set it here if you need a custom host/port/db.
# DATABASE_URL=postgresql+asyncpg://agent:change_me_in_production@postgres:5432/agent_platform

# Optional tuning
# DEBUG=true
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:5173,https://your-prod-domain.com
