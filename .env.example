# Copy to .env and fill in values.
# All variables here are read by docker-compose and by the backend (pydantic-settings).

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Postgres password — used by both the postgres service and the backend DATABASE_URL.
# Change this for any environment beyond your local machine.
POSTGRES_PASSWORD=change_me_in_production

# Override the default DATABASE_URL if you're not using docker-compose
# (e.g. pointing at an external Postgres instance).
# The docker-compose.yml constructs this automatically from POSTGRES_PASSWORD;
# only set it here if you need a custom host/port/db.
# DATABASE_URL=postgresql+asyncpg://agent:change_me_in_production@postgres:5432/agent_platform

# Optional tuning
# DEBUG=true
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:5173,https://your-prod-domain.com

# ---------------------------------------------------------------------------
# Identity / multi-tenancy (AD-group based)
#
# In production, deploy the backend behind an SSO reverse proxy (Azure AD App
# Proxy, ADFS WAP, oauth2-proxy, ...) that authenticates users against Active
# Directory and injects these headers on every request:
#   X-Auth-User-Email, X-Auth-User-Name, X-Auth-Groups (comma-separated)
# Workspace membership and roles are derived from AD groups via the
# tenant_group_mappings table (managed in the UI under Settings).
#
# AUTH_DEV_FALLBACK=true (the default) makes requests WITHOUT identity headers
# act as the dev identity below. Set it to false in production so unproxied
# requests are rejected with 401.
# ---------------------------------------------------------------------------
# AUTH_DEV_FALLBACK=true
# DEV_USER_EMAIL=dev@example.com
# DEV_USER_NAME=Dev User
# DEV_USER_GROUPS=agent-platform-admins,agent-platform-users
# AUTH_USER_HEADER=X-Auth-User-Email
# AUTH_NAME_HEADER=X-Auth-User-Name
# AUTH_GROUPS_HEADER=X-Auth-Groups
